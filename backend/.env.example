# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file and rename to: .env
# Then replace all XXXXX values with your actual links
# ============================================

# ✅ REQUIRED - DATABASE CONNECTION
# Get this from: https://www.mongodb.com/cloud/atlas
# Steps: 1. Sign up → 2. Create cluster → 3. Click Connect → 4. Copy connection string
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/financial-dashboard?retryWrites=true&w=majority

# ✅ REQUIRED - JWT AUTHENTICATION SECRET
# Generate random string using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This secures login tokens - make it unique and random
JWT_SECRET=your-random-secret-key-here-generate-a-random-string

# ✅ REQUIRED - SERVER PORT
# Usually 5000 for backend
PORT=5000

# ✅ REQUIRED - ENVIRONMENT MODE
# Options: development, production, test
NODE_ENV=development

# ✅ REQUIRED - FRONTEND URL (for CORS)
# This is where your Next.js frontend is running
FRONTEND_URL=http://localhost:3000

# ============================================
# OPTIONAL - PAYMENT PROCESSING (Stripe)
# ============================================
# Get this from: https://stripe.com → Developers → API Keys
# Only needed if you want payment features
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# OPTIONAL - EMAIL NOTIFICATIONS (SendGrid)
# ============================================
# Get this from: https://sendgrid.com → Settings → API Keys
# Only needed if you want email features
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# OPTIONAL - AWS S3 (File uploads)
# ============================================
# Get from: https://aws.amazon.com → S3 console
# Only needed if you want to upload files
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1

# ============================================
# OPTIONAL - LOGGING & MONITORING
# ============================================
# Get from: https://sentry.io (error tracking)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# OPTIONAL - ANALYTICS
# ============================================
# Get from: https://mixpanel.com
MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# NOTES:
# ============================================
# 1. Never commit this file to GitHub - it's in .gitignore
# 2. All lines starting with ✅ are REQUIRED for basic functionality
# 3. All lines starting with ❌ are OPTIONAL - only add if you use those features
# 4. In production, use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# ============================================
