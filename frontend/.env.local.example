# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file and rename to: .env.local
# Most values are already filled in - you usually don't need to change anything
# ============================================

# ✅ REQUIRED - Backend API URL
# This tells the frontend where to send API requests
# Local development: http://localhost:5000/api
# Production: https://your-api-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ❌ OPTIONAL - Analytics (if using Google Analytics)
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ❌ OPTIONAL - Stripe Public Key (if using payments)
# Get from: https://stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# NOTES:
# ============================================
# 1. "NEXT_PUBLIC_" prefix means these values are visible in browser (OK for non-secret data)
# 2. Never add sensitive keys (JWT_SECRET, database passwords) to frontend .env
# 3. All API keys here should be "public" keys only
# 4. For local testing, just use the defaults - they point to your local backend
# ============================================
